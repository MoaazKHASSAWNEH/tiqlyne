{
  "name": "@tiqlyne/motion-core",
  "version": "0.1.0",
  "description": "Core package for Tiqlyne Motion Engine.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "author": "Moaaz KHASSAWNEH",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
